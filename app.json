{
  "expo": {
    "name": "Inventory App",
    "slug": "inventory-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "infoPlist": {
        "NFCReaderUsageDescription": "Used to read Harvard HUID cards for member enrollment."
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": ["TAG"]
      }
    },
    "android": {
      "package": "com.inventoryapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.NFC"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Inventory App to access your camera for barcode scanning."
        }
      ],
      "./plugins/withNfc"
    ]
  }
}
